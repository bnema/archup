[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = linux
Target = linux-lts
Target = linux-zen
Target = linux-hardened
Target = linux-cachyos

[Action]
Description = Updating Limine bootloader after kernel upgrade...
When = PostTransaction
Exec = /bin/sh -c '[ -d /sys/firmware/efi ] || /usr/bin/limine bios-install DISK_PLACEHOLDER'
Depends = limine
